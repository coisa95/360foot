# ============================================================================
# 360 Foot — Variables d'environnement
# Copier ce fichier en .env et remplir toutes les valeurs
# ============================================================================

# ───── Supabase (Phase 2 : encore Supabase Cloud) ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ───── APIs externes ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
API_FOOTBALL_KEY=...
PEXELS_API_KEY=...
UNSPLASH_ACCESS_KEY=...

# ───── Telegram (publication automatique articles) ─────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHANNEL_ID=@foot360news

# ───── Authentification CRON ────────────────────────────────────────────────
CRON_SECRET=<generate with: openssl rand -base64 32>

# ───── Upstash Redis (Phase 2) — sera remplacé par Redis local en Phase 3 ─
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ───── PostgreSQL self-hosted (Phase 4 uniquement) ──────────────────────────
POSTGRES_PASSWORD=<generate with: openssl rand -base64 32>
DATABASE_URL=postgresql://postgres:PASSWORD@postgres:5432/foot360
